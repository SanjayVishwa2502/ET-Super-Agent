{
  "name": "et-super-agent-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:fallback": "cross-env SIMULATE_KG_UNAVAILABLE=true tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:data",
    "copy:data": "node -e \"const fs=require('fs'); fs.mkdirSync('dist/data',{recursive:true}); fs.copyFileSync('src/data/kg.json','dist/data/kg.json');\"",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.2.74",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
