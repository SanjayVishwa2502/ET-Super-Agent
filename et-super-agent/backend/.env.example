PORT=4000

# LangGraph
USE_LANGGRAPH=true

# Intelligence mode
# Keep false for fully zero-cost fallback mode.
USE_LLM=false

# Provider: auto | local | openrouter | groq | huggingface
MODEL_PROVIDER=auto

# Local model (optional)
LOCAL_MODEL_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.2:3b

# OpenRouter (free models available with quota)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=ET Super Agent

# Groq (free developer tier quotas)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Hugging Face Router (free tier quotas)
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
HF_BASE_URL=https://router.huggingface.co/v1

# LLM tuning
LLM_TIMEOUT_MS=15000
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.7

FEATURE_VOICE=false
SIMULATE_KG_UNAVAILABLE=false
