PORT=4040

# LangGraph
USE_LANGGRAPH=true

# Intelligence mode
# Keep false for fully zero-cost fallback mode.
USE_LLM=false

# Provider: auto | local | openrouter | groq | huggingface
MODEL_PROVIDER=auto

# Local model (optional)
LOCAL_MODEL_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.2:3b

# OpenRouter (free models available with quota)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=ET Super Agent

# Groq (free developer tier quotas)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Hugging Face Router (free tier quotas)
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
HF_BASE_URL=https://router.huggingface.co/v1

# LLM tuning
LLM_TIMEOUT_MS=15000
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.7

FEATURE_VOICE=false
SIMULATE_KG_UNAVAILABLE=false

# SQL persistence
# Local default: SQLite file at backend/data/et-super-agent.db
# Vercel/production: set POSTGRES_URL (or DATABASE_URL) for durable SQL storage.
POSTGRES_URL=
DATABASE_URL=

# Optional URL aliases from common integrations
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Optional component-based fallback (used to build URL when above are empty)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_SSLMODE=require
# Set to false for providers using self-signed/intermediate cert chains (e.g., some Supabase poolers)
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Optional SQLite override path (used when Postgres URL is not set)
SQLITE_DB_PATH=

# Optional session persistence tuning
SESSION_TTL_SECONDS=604800
